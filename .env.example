NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
HERMES_PORT=4010
COMPOSE_PROJECT_NAME=life-os
POSTGRES_DB=life_os
POSTGRES_USER=life_os
POSTGRES_PASSWORD=life_os
DATABASE_URL=postgresql://life_os:life_os@postgres:5432/life_os
REDIS_URL=redis://redis:6379
VITE_API_BASE_URL=http://localhost:4000
LIFE_OS_DEFAULT_WORKSPACE_SLUG=default
API_CORS_ORIGINS=http://localhost:3000
API_RATE_LIMIT_MAX=600
API_RATE_LIMIT_WINDOW=1 minute
HERMES_URL=http://hermes:4010
HERMES_MODE=fallback
HERMES_API_TOKEN=
POSTGRES_BACKUP_DIR=./backups/postgres
POSTGRES_BACKUP_KEEP_DAYS=14
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
OPS_MONITOR_INTERVAL_SECONDS=300
OPS_MONITOR_MAX_BACKUP_AGE_SECONDS=172800
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_MIN_SECONDS_BETWEEN_NOTIFICATIONS=1800
OPS_API_HEALTH_URL=http://localhost:4000/health
OPS_WEB_HEALTH_URL=http://localhost:3000/
OPS_HERMES_HEALTH_URL=http://localhost:4010/health
LIFE_OS_IMAGE_TAG=local
LIFE_OS_IMAGE_API=life-os-api
LIFE_OS_IMAGE_WORKER=life-os-worker
LIFE_OS_IMAGE_WEB=life-os-web
LIFE_OS_IMAGE_HERMES=life-os-hermes
